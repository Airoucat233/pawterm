{
  "name": "pawterm",
  "private": true,
  "description": "Mobile + Web control surface for AI coding assistants",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=pawterm-server --filter=@pawterm/web run dev",
    "dev:server": "pnpm --filter pawterm-server run dev",
    "dev:web": "pnpm --filter @pawterm/web run dev",
    "build": "pnpm --filter @pawterm/web run build && pnpm --filter pawterm-server run build",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.31.0"
}
