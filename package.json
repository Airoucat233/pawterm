{
  "name": "pawterm",
  "private": true,
  "description": "Mobile + Web control surface for AI coding assistants",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:all": "pnpm run dev",
    "dev:server": "pnpm --filter pawterm-server run dev",
    "dev:server:test": "pnpm --filter pawterm-server run dev:test",
    "dev:web": "pnpm --filter @pawterm/web run dev",
    "dev:android": "node scripts/dev-android.cjs",
    "build": "pnpm run build:server",
    "build:all": "pnpm run build:server && pnpm run build:app && pnpm run build:mac",
    "build:app": "cd app && zsh scripts/build-apk.sh --dev",
    "build:app:prod": "cd app && zsh scripts/build-apk.sh --prod",
    "build:ios": "cd app && zsh scripts/build-ipa.sh",
    "build:mac": "cd mac && zsh scripts/build.sh --dev",
    "build:mac:install": "cd mac && zsh scripts/build.sh --dev --install",
    "build:mac:prod": "cd mac && zsh scripts/build.sh --prod",
    "build:server": "pnpm run build:web && pnpm --filter pawterm-server run build",
    "build:web": "pnpm --filter @pawterm/web run build",
    "release": "zsh scripts/release.sh",
    "release:local": "zsh scripts/release.sh --local",
    "release:pre": "zsh scripts/release.sh --prerelease",
    "release:pre:local": "zsh scripts/release.sh --prerelease --local",
    "start": "pnpm run start:server",
    "start:server": "pnpm --filter pawterm-server run start",
    "preview:web": "pnpm --filter @pawterm/web run preview",
    "typecheck": "pnpm -r run typecheck",
    "typecheck:server": "pnpm --filter pawterm-server run typecheck",
    "typecheck:web": "pnpm --filter @pawterm/web run typecheck",
    "test:server": "pnpm --filter pawterm-server run test",
    "test:server:watch": "pnpm --filter pawterm-server run test:watch"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.31.0"
}
